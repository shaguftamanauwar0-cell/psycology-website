# ── Database (Supabase Postgres) ───────────────────────────────────────────
# Supabase Dashboard → Project → Connect → "Connection string" (URI).
# Use the pooler connection. Example:
#   postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Run supabase/schema.sql once in the Supabase SQL Editor to create the tables.
DATABASE_URL=

# ── Admin panel (/admin) ───────────────────────────────────────────────────
ADMIN_PASSWORD=
# A long random string used to sign the admin session cookie.
ADMIN_SESSION_SECRET=

# ── Payment ────────────────────────────────────────────────────────────────
# The UPI QR shown to users lives at public/upi-qr.jpg.
# Optionally also show a UPI ID as text (public — shown to users):
NEXT_PUBLIC_UPI_ID=
NEXT_PUBLIC_UPI_NAME=Shagufta Manauwar

# ── Gmail SMTP (email notifications) ───────────────────────────────────────
# Google Account → Security → 2-Step Verification → App passwords → "Mail".
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Optional second recipient for booking notifications.
NOTIFY_EMAIL=
