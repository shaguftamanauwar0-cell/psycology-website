# ── Supabase (database for bookings, slots, messages) ──────────────────────
# Create a project at https://supabase.com, then:
#   Project Settings → Data API → Project URL   → SUPABASE_URL
#   Project Settings → API Keys → service_role  → SUPABASE_SERVICE_ROLE_KEY
# Then run supabase/schema.sql in the SQL Editor once.
# The service_role key is SECRET — server-only, never expose it to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel (/admin) ───────────────────────────────────────────────────
# The single shared password used to sign into the admin dashboard.
ADMIN_PASSWORD=
# A long random string used to sign the admin session cookie.
ADMIN_SESSION_SECRET=

# ── Payment (shown to users after they book) ───────────────────────────────
# Your UPI ID and the name that appears in UPI apps. Public (shown to users).
NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_NAME=Shagufta Manauwar

# ── Gmail SMTP (email notifications) ───────────────────────────────────────
# 1. Enable 2-Step Verification on the Google account.
# 2. Google Account → Security → 2-Step Verification → App passwords
# 3. Create an app password for "Mail", paste the 16 chars (no spaces) below.
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Optional second recipient for booking notifications (e.g. your own inbox).
NOTIFY_EMAIL=
