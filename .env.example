# Convex deployment URL (from `npx convex dev` or the Convex dashboard).
# The contact form persists messages to Convex when this is set.
# Example: https://grateful-capybara-594.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Gmail SMTP — for email notifications when someone submits the intake form.
# 1. Enable 2-Step Verification on your Google account (required).
# 2. Go to: Google Account → Security → 2-Step Verification → App passwords
# 3. Create an app password for "Mail" (select "Other" as device, name it "Shagufta Website")
# 4. Copy the 16-character password (no spaces) into GMAIL_APP_PASSWORD below.
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
